# Database Configuration
DB_NAME=mi_proyecto_db
DB_USER=postgres
DB_PASSWORD=postgres123
POSTGRES_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# Django Backend Configuration
SECRET_KEY=django-insecure-change-this-in-production-very-long-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend,nginx,192.168.100.27
BACKEND_PORT=8000

# Frontend Configuration
FRONTEND_PORT=4200
NODE_ENV=development

# Nginx Configuration
NGINX_PORT=80

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True

# Security
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://192.168.100.27:4200

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# File Upload Configuration
MAX_UPLOAD_SIZE=10485760
UPLOAD_PATH=/app/media

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log
