# Frontend Configuration
NODE_ENV=production
FRONTEND_PORT=80

# Backend Configuration (for development)
BACKEND_URL=http://192.168.100.27:8000
BACKEND_API_URL=http://192.168.100.27:8000/api

# Build Configuration
BUILD_TARGET=production
OUTPUT_PATH=dist/mi-proyecto-frontend

# Nginx Configuration
NGINX_PORT=80
NGINX_HOST=localhost

# Development Configuration
DEV_SERVER_PORT=4200
DEV_SERVER_HOST=localhost

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined

# Performance
ENABLE_COMPRESSION=true
ENABLE_CACHING=true
CACHE_MAX_AGE=31536000

# Security
ENABLE_HTTPS=false
SECURITY_HEADERS=true

# Features
ENABLE_ANALYTICS=false
ENABLE_ERROR_TRACKING=false
